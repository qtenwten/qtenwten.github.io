    "check:addressee:profile-adapter": "node scripts/check-addressee-profile-adapter.js",
    "check:addressee:trust-layer": "node scripts/check-addressee-trust-layer.js",
    "check:addressee:scenario-ux": "node scripts/check-addressee-scenario-ux.js",
    "check:addressee:mobile-qa": "node scripts/check-addressee-mobile-qa.cjs",
