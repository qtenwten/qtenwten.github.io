{
  "name": "utility-tools-site",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/generate-pages.js",
    "preview": "vite preview",
    "deploy": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
