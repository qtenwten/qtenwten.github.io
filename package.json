  "dependencies": {
    "@sentry/react": "^10.49.0",
    "chart.js": "^4.5.1",
    "docx": "^9.6.1",
    "expr-eval": "^2.0.2",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.8.0",
    "node-fetch": "^3.3.2",
    "pdf-lib": "^1.17.1",
    "qrcode": "^1.5.4",
    "react": "^18.2.0",
    "react-chartjs-2": "^5.3.1",
